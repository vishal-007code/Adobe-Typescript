{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist"
  },

  "include": [
    "src/**/*.ts",
    "tests/adobe/script.spec.ts",
    "playwright.config.ts"
  ],

  "exclude": [
    "node_modules",
    "test-results",
    "playwright-report",
    "tests/adobe/script.low-network.debug.spec.ts",
    "tests/internal/**/*.ts"
  ]
}
